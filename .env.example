# Copy this file to .env and fill in your values
ANTHROPIC_API_KEY=sk-ant-...

# --- Model tiers (Opt. 3: tiered routing) ---
SWARM_MODEL_SIMPLE=claude-haiku-4-5-20251001    # simple leaf tasks
SWARM_MODEL_MEDIUM=claude-sonnet-4-6            # default executor/reviewer
SWARM_MODEL_COMPLEX=claude-opus-4-7             # decomposer + synthesizer

# --- Concurrency ---
SWARM_MAX_AGENTS=8
SWARM_MAX_DEPTH=4        # max task decomposition depth

# --- Batch API (Opt. 4: 50% cheaper for independent tasks) ---
# Set to true to use the Message Batches API for independent leaf tasks.
# Results may take minutes instead of seconds.
SWARM_USE_BATCHING=false
SWARM_BATCH_MIN=2        # minimum tasks per batch (below this → real-time)
